[core]
	editor = vim
	quotepath = false
[fetch]
	prune = true
[alias]
	a = add
	b = branch
	c = commit
	df = diff
	graph = log --graph --all --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	; graph = log --graph --all --date=short --pretty=\"format:'%C(yellow)%h %C(cyan)%ad %C(green)%an%Creset%09%s %C(red)%d%Creset\"
	l = log
	sh = stash
	st = status
	sw = switch

